  <data name="CEO Says" xml:space="preserve">
    <value>Yaptığımız işi seviyoruz ve başkalarına sevdiği işi yaparken yardım etmekten mutluluk duyuyoruz.</value>
  </data>
  <data name="Marketing Manager" xml:space="preserve">
