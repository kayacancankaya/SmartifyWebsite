@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@section Title {
	<title>@Localizer["SmartifyYourBusiness"]</title>
}
@section Description {
	<meta name="description" content="@Localizer["SmartifyDescription"]">
}
@section Keywords {
	<meta name="keywords" content="@Localizer["IndexKeywords"]">
}


			<section class="page_title ls s-py-50 corner-title ls invise overflow-visible">
				<div class="container">
					<div class="row">
						<div class="col-md-12 text-center">
							<h1>404</h1>
							<ol class="breadcrumb">
								<li class="breadcrumb-item">
									<a asp-controller="Home" asp-action="Index">@Localizer["MainPage"]</a>
								</li>
								<li class="breadcrumb-item active">
									404
								</li>
							</ol>
							<div class="divider-15 d-none d-xl-block"></div>
						</div>
					</div>
				</div>
			</section>


			<section class="ls s-pt-50 s-pb-100 error-404 not-found page_404">
				<div class="container">
					<div class="row">
						<div class="col-sm-12 text-center">

							<header class="page-header">
								<p>
									@Localizer["Oops, Page not found"]
								</p>
							</header>
							<!-- .page-header -->

							<div class="page-content">
								<div  >

									<p style="color:black;font-weight:bold">
										@Localizer["Oops, Page not found P"]<br>
										@Localizer["Oops, Page not found P2"]
									</p>
								</div>

								<p>
									<a asp-controller="Home" asp-action="Index" class="btn btn-maincolor">@Localizer["MainPage"]</a>
								</p>
							</div>
							<!-- .page-content -->
						</div>
					</div>
				</div>
				<div class="d-none d-lg-block divider-120"></div>
			</section>
